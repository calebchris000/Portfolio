{
    "compilerOptions": {
      "moduleResolution": "node",
      "module": "es2020",
      "lib": ["es2020", "dom"],
      "target": "es2020",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "sourceMap": true,
      "baseUrl": ".",
      "paths": {
        "src/*": ["src/*"]
      }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules/*", "public/*"]
  }